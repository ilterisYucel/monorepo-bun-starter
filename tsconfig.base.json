{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    // ===== NX İÇİN EKLENEN AYARLAR =====
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false, // Root'da false, alt projelerde true olacak
    "emitDeclarationOnly": false,
    "noEmit": false, // Base'de false, root'da true olacak

    // ===== MONOREPO PATHS AYARLARI =====
    "paths": {
      "@gd-monorepo/shared-types": ["./packages/shared-types/src"],
      "@gd-monorepo/shared-utils": ["./packages/shared-utils/src"],
      "@gd-monorepo/core": ["./packages/core/src"],
      "@gd-monorepo/web": ["./apps/web/src"],
      "@gd-monorepo/desktop": ["./apps/desktop/src"],
      "@gd-monorepo/backend": ["./apps/backend/src"],
      "@gd-monorepo/simulators": ["./packages/simulators/src"]
    }
  },
  "exclude": ["node_modules", "dist", "out", "release", "**/dist", "**/out"]
}
