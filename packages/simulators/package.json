{
  "name": "@gd-monorepo/simulators",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./xrack": {
      "types": "./src/xrack/index.ts",
