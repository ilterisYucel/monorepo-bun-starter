{
  "deviceId": "CB-1",
  "name": "DC Circuit Breaker 1",
  "manufacturer": "Generic",
  "model": "CB-480-630A",
  "protocol": "MODBUS",
  "connection": {
    "host": "127.0.0.1",
    "port": 530,
    "slaveId": 1
  },
  "telemetry": [
    {
      "name": "Is Closed",
      "description": "Breaker closed status",
      "unit": "-",
      "protocol": "MODBUS",
      "registerAddress": 0,
      "registerTableType": "DISCRETE_INPUT",
      "registerDataType": "BOOLEAN",
      "scale": 1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    },
    {
      "name": "Is Tripped",
      "description": "Breaker trip status",
      "unit": "-",
      "protocol": "MODBUS",
      "registerAddress": 1,
      "registerTableType": "DISCRETE_INPUT",
      "registerDataType": "BOOLEAN",
      "scale": 1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    },
    {
      "name": "Current",
      "description": "Current flowing through breaker",
      "unit": "A",
      "protocol": "MODBUS",
      "registerAddress": 0,
      "registerTableType": "INPUT_REGISTER",
      "registerDataType": "UINT16",
      "scale": 0.1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    },
    {
      "name": "Voltage",
      "description": "Line side voltage",
      "unit": "V",
      "protocol": "MODBUS",
      "registerAddress": 1,
      "registerTableType": "INPUT_REGISTER",
      "registerDataType": "UINT16",
      "scale": 0.1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    },
    {
      "name": "Temperature",
      "description": "Breaker temperature",
      "unit": "°C",
      "protocol": "MODBUS",
      "registerAddress": 2,
      "registerTableType": "INPUT_REGISTER",
      "registerDataType": "UINT16",
      "scale": 0.1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    },
    {
      "name": "Trip Count",
      "description": "Number of trip events",
      "unit": "-",
      "protocol": "MODBUS",
      "registerAddress": 3,
      "registerTableType": "INPUT_REGISTER",
      "registerDataType": "UINT16",
      "scale": 1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    },
    {
      "name": "Operate Count",
      "description": "Number of open/close cycles",
      "unit": "-",
      "protocol": "MODBUS",
      "registerAddress": 4,
      "registerTableType": "INPUT_REGISTER",
      "registerDataType": "UINT16",
      "scale": 1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    },
    {
      "name": "Trip Threshold",
      "description": "Overcurrent trip threshold",
      "unit": "A",
      "protocol": "MODBUS",
      "registerAddress": 0,
      "registerTableType": "HOLDING_REGISTER",
      "registerDataType": "UINT16",
      "scale": 0.1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    },
    {
      "name": "UV Threshold",
      "description": "Undervoltage threshold",
      "unit": "V",
      "protocol": "MODBUS",
      "registerAddress": 1,
      "registerTableType": "HOLDING_REGISTER",
      "registerDataType": "UINT16",
      "scale": 0.1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    },
    {
      "name": "OV Threshold",
      "description": "Overvoltage threshold",
      "unit": "V",
      "protocol": "MODBUS",
      "registerAddress": 2,
      "registerTableType": "HOLDING_REGISTER",
      "registerDataType": "UINT16",
      "scale": 0.1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    },
    {
      "name": "Open",
      "description": "Open breaker command",
      "unit": "-",
      "protocol": "MODBUS",
      "registerAddress": 0,
      "registerTableType": "COIL",
      "registerDataType": "BOOLEAN",
      "scale": 1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    },
    {
      "name": "Close",
      "description": "Close breaker command",
      "unit": "-",
      "protocol": "MODBUS",
      "registerAddress": 1,
      "registerTableType": "COIL",
      "registerDataType": "BOOLEAN",
      "scale": 1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    },
    {
      "name": "Reset",
      "description": "Reset trip command",
      "unit": "-",
      "protocol": "MODBUS",
      "registerAddress": 2,
      "registerTableType": "COIL",
      "registerDataType": "BOOLEAN",
      "scale": 1,
      "offset": 0,
      "priority": 0,
      "byteOrder": "BIG_ENDIAN",
      "tags": { "deviceId": "CB-1" }
    }
  ],
  "pollIntervalMs": 2000,
  "commands": {
    "open": {
      "label": "Aç (Open)",
      "telemetries": [{ "name": "Open", "value": 1 }],
      "timeoutMs": 2000,
      "validate": {
        "reads": [{ "name": "Is Closed", "expect": false }]
      }
    },
    "close": {
      "label": "Kapat (Close)",
      "telemetries": [{ "name": "Close", "value": 1 }],
      "timeoutMs": 2000,
      "validate": {
        "reads": [{ "name": "Is Closed", "expect": true }]
      }
    },
    "reset": {
      "label": "Reset Trip",
      "telemetries": [{ "name": "Reset", "value": 1 }],
      "timeoutMs": 2000,
      "validate": {
        "reads": [{ "name": "Is Tripped", "expect": false }]
      }
    }
  },
  "simulator": { "type": "cb" }
}
