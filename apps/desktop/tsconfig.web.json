{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@gd-monorepo/shared-types": ["../../packages/shared-types/src"],
      "@gd-monorepo/shared-utils": ["../../packages/shared-utils/src"],
      "@gd-monorepo/ui": ["../../packages/ui/src"],
      "@gd-monorepo/ui/*": ["../../packages/ui/src/*"],
      "@gd-monorepo/web": ["../../apps/web/src"],
      "@gd-monorepo/web/*": ["../../apps/web/src/*"]
    }
  },
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts"
  ]
}