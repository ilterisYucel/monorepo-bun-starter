{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./out/renderer",
    "rootDir": "./src/renderer",
    "noEmit": false,
    "emitDeclarationOnly": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@gd-monorepo/shared-types": ["../../packages/shared-types/src"],
      "@gd-monorepo/shared-utils": ["../../packages/shared-utils/src"]
    }
  },
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts"
  ]
}